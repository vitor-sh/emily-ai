# ─────────────────────────────────────────────────────────────────
# DADOS PESSOAIS E CACHE LOCAL gerados pela Emily
# ─────────────────────────────────────────────────────────────────

# Memória persistente — contém fatos pessoais sobre o usuário
memoria.json

# Configurações e cache do Discord (token, IDs de canal)
.emily_discord.json

# Modos configurados pelo usuário
.emily_modos.json

# Cache de speedruns/inputs gravados
.emily_speedruns.json

# Cache de apps Steam (lista de jogos da conta)
.emily_steam_applist.json

# Cache de LLM e outros caches locais
.emily_cache.json
.emily_llm_cache.json

